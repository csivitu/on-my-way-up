{
  "name": "on-my-way-up",
  "version": "1.0.0",
  "description": "A game built using PhaserJS where you control a player character to go as high up as possible.",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "bun run --watch index.js",
    "start": "bun run index.js",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "prepare": "husky install"
  },
  "keywords": [
    "game",
    "phaser",
    "javascript"
  ],
  "author": "Vibhor Agrawal",
  "license": "MIT",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.0",
    "eslint": "^9.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.3",
    "express": "^4.18.2"
  },
  "lint-staged": {
    "**/*.{js,ts,jsx,tsx,json,md,css}": "prettier --write"
  }
}
